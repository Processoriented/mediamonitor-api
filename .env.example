## Docker Compose env (copy to .env)

# Published host port -> container 8787
API_PORT=8787

# Bind address inside container
HOST=::

# Logging
LOG_LEVEL=info

# SQLite filename inside /data volume
SQLITE_FILE=mediamonitor.sqlite

# Webhook authentication (recommended)
WEBHOOK_SECRET=change-me

# Background polling (seconds)
POLL_INTERVAL_SECONDS=30

# Integrations (optional; used as pollers are implemented)
SEERR_BASE_URL=
SEERR_API_KEY=

SONARR_BASE_URL=
SONARR_API_KEY=

RADARR_BASE_URL=
RADARR_API_KEY=

SABNZBD_BASE_URL=
SABNZBD_API_KEY=

TAUTULLI_BASE_URL=
TAUTULLI_API_KEY=

# Optional host signal paths (only used if you run with docker-compose.host-signals.yml)
SABNZBD_PULL_LOG_PATH=/path/to/sabnzbd_pull.log
SABNZBD_PULL_STATE_PATH=/path/to/sabnzbd_pull_state.json

# In-container ingest paths (only change if you remap the volumes)
SABNZBD_PULL_LOG_INGEST_PATH=/host/logs/sabnzbd_pull.log
SABNZBD_PULL_STATE_INGEST_PATH=/host/state/sabnzbd_pull_state.json

